# Copy to .env and fill in your keys:
#   cp .env.example .env
#
# wiki_build loads .env automatically when you run, e.g.:
#   python -m wiki_build.pipeline
#
# Shell exports override .env values. This file is safe to commit (no real secrets).

# --- API keys (read by each provider's SDK) ---
# Only set the keys for providers you use.

GOOGLE_API_KEY=your-google-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- Hybrid pipeline (recommended) ---
# Per-stage provider/model. Uncomment to override defaults in wiki_build/llm_client.py.

# WIKI_LLM_CLASSIFY_PROVIDER=gemini
# WIKI_LLM_CLASSIFY_MODEL=gemini-2.0-flash
# WIKI_LLM_EXTRACT_PROVIDER=anthropic
# WIKI_LLM_EXTRACT_MODEL=claude-sonnet-4-20250514
# WIKI_LLM_GENERATE_PROVIDER=anthropic
# WIKI_LLM_GENERATE_MODEL=claude-sonnet-4-20250514

# --- Single provider for all stages (alternative) ---
# Uncomment instead of per-stage vars above.

# WIKI_LLM_PROVIDER=anthropic
# WIKI_LLM_MODEL=claude-3-5-sonnet-latest

# --- Batch API (optional, 50% cheaper, async) ---
# Pass --batch to python -m wiki_build.pipeline (or classify / extract / generate).
# Supported providers: gemini (classify), anthropic (extract / generate).
# WIKI_LLM_BATCH_POLL_INTERVAL=30
